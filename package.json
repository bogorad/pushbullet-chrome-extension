{
  "name": "pushbullet-chrome-extension",
  "version": "1.5.2",
  "description": "Unofficial Manifest V3 compatible Pushbullet client for Chrome",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "build": "node scripts/build-extension.js",
    "bump-patch": "node scripts/bump-patch.cjs"
  },
  "keywords": [
    "pushbullet",
    "chrome-extension",
    "manifest-v3"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.1.19",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.6.2",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.25.10",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "vitest-chrome": "^0.1.0"
  }
}
